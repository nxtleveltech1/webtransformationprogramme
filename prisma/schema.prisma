  entityExternalId String
  workshopDay      Int?
  sessionRef       String?
  sourceExternalId String?
  segment          String?
  rawTrace         String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([entityExternalId])
  @@index([sourceExternalId])
}

model AuditEvent {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actorName  String?
  actorRole  String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

// ─── Enterprise PM extension ─────────────────────────────────────────────────

enum Rag {
  RED
  AMBER
  GREEN
}

enum ProjectStatus {
  PROPOSED
  ACTIVE
  ON_HOLD
  COMPLETE
  CANCELLED
}

enum DeliverableStatus {
  NOT_STARTED
  IN_PROGRESS
  AT_RISK
  COMPLETE
  CANCELLED
}

enum ChangeRequestStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationType {
  INFO
  WARNING
  ESCALATION
  APPROVAL_REQUEST
  MENTION
  REMINDER
}

enum DocumentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  ARCHIVED
}

enum PhaseStatus {
  NOT_STARTED
  IN_PROGRESS
  AT_RISK
  COMPLETE
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETE
  DEFERRED
}

enum ReadinessGateStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  READY
  APPROVED
  REJECTED
}

enum GovernanceMeetingType {
  STEERING_COMMITTEE
  LEAD_PLANNING
  PLAYBACK
  SME_WORKSHOP
  SIGN_OFF
  GO_NO_GO
  HYPERCARE_STANDUP
  DECISION_FORUM
  WORKSTREAM_CHECKPOINT
}

enum EvidenceLinkKind {
  SUPPORTS
  INFERRED_FROM
  REQUIRES_VALIDATION
  GAP
}

model Phase {
  id             String          @id @default(cuid())
  programmeId    String
  programme      Programme       @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  code           String
  name           String
  purpose        String?         @db.Text
  status         PhaseStatus     @default(NOT_STARTED)
  startDate      String?
  endDate        String?
  sortOrder      Int             @default(0)
  confidence     Confidence      @default(INFERRED)
  traceRef       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tasks          Task[]
  deliverables   Deliverable[]
  milestones     Milestone[]
  readinessGates ReadinessGate[]
  statusUpdates  StatusUpdate[]

  @@unique([programmeId, code])
  @@index([programmeId])
  @@index([status])
}

model Task {
  id                 String           @id @default(cuid())
  externalId         String           @unique
  programmeId        String?
  programme          Programme?       @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  phaseId            String?
  phase              Phase?           @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  workstreamId       String?
  workstream         Workstream?      @relation(fields: [workstreamId], references: [id], onDelete: SetNull)
  projectId          String?
  project            Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  deliverableId      String?
  deliverable        Deliverable?     @relation(fields: [deliverableId], references: [id], onDelete: SetNull)
  milestoneId        String?
  milestone          Milestone?       @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  parentTaskId       String?
  parentTask         Task?            @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks         Task[]           @relation("TaskHierarchy")
  title              String
  description        String?          @db.Text
  status             TaskStatus       @default(NOT_STARTED)
  priority           Priority         @default(MEDIUM)
  rag                Rag?
  percentComplete    Int              @default(0)
  baselineStartDate  String?
  baselineEndDate    String?
  forecastStartDate  String?
  forecastEndDate    String?
  durationDays       Int?
  ownerPersonId      String?
  ownerPerson        Person?          @relation("TaskOwner", fields: [ownerPersonId], references: [id], onDelete: SetNull)
  ownerText          String?
  supportingSmes     String?          @db.Text
  blockers           String?          @db.Text
  acceptanceCriteria String?          @db.Text
  completionEvidence String?          @db.Text
  assumptions        String?          @db.Text
  confidence         Confidence       @default(INFERRED)
  criticalPath       Boolean          @default(false)
  sourceDocumentId   String?
  sourceDocument     SourceDocument?  @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  traceRef           String?
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  predecessorLinks   TaskDependency[] @relation("TaskDependencyPredecessor")
  successorLinks     TaskDependency[] @relation("TaskDependencySuccessor")
  actions            Action[]
  risks              Risk[]
  issues             Issue[]
  decisions          Decision[]
  dependencies       Dependency[]
  readinessGates     ReadinessGate[]
  statusUpdates      StatusUpdate[]
  evidenceLinks      EvidenceLink[]

  @@index([programmeId])
  @@index([phaseId])
  @@index([workstreamId])
  @@index([projectId])
  @@index([deliverableId])
  @@index([milestoneId])
  @@index([parentTaskId])
  @@index([status])
  @@index([criticalPath])
}

model TaskDependency {
  id                String   @id @default(cuid())
  predecessorTaskId String
  predecessorTask   Task     @relation("TaskDependencyPredecessor", fields: [predecessorTaskId], references: [id], onDelete: Cascade)
  successorTaskId   String
  successorTask     Task     @relation("TaskDependencySuccessor", fields: [successorTaskId], references: [id], onDelete: Cascade)
  dependencyType    String?
  lagDays           Int?
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([predecessorTaskId, successorTaskId])
  @@index([successorTaskId])
}

model ReadinessGate {
  id               String               @id @default(cuid())
  externalId       String               @unique
  programmeId      String?
  programme        Programme?           @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  phaseId          String?
  phase            Phase?               @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  workstreamId     String?
  workstream       Workstream?          @relation(fields: [workstreamId], references: [id], onDelete: SetNull)
  projectId        String?
  project          Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  deliverableId    String?
  deliverable      Deliverable?         @relation(fields: [deliverableId], references: [id], onDelete: SetNull)
  taskId           String?
  task             Task?                @relation(fields: [taskId], references: [id], onDelete: SetNull)
  name             String
  category         String
  criteria         String               @db.Text
  evidenceRequired String               @db.Text
  ownerPersonId    String?
  ownerPerson      Person?              @relation("ReadinessGateOwner", fields: [ownerPersonId], references: [id], onDelete: SetNull)
  ownerText        String?
  status           ReadinessGateStatus  @default(NOT_STARTED)
  rag              Rag?
  decisionRequired String?              @db.Text
  blockingIssues   String?              @db.Text
  dueDate          String?
  approvalDate     String?
  approvalId       String?
  confidence       Confidence           @default(INFERRED)
  sourceDocumentId String?
  sourceDocument   SourceDocument?      @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  traceRef         String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  criteriaItems    ReadinessCriterion[]
  evidenceLinks    EvidenceLink[]
  statusUpdates    StatusUpdate[]

  @@index([programmeId])
  @@index([phaseId])
  @@index([workstreamId])
  @@index([projectId])
  @@index([deliverableId])
  @@index([taskId])
  @@index([status])
  @@index([rag])
}

model ReadinessCriterion {
  id               String              @id @default(cuid())
  readinessGateId  String
  readinessGate    ReadinessGate       @relation(fields: [readinessGateId], references: [id], onDelete: Cascade)
  description      String              @db.Text
  evidenceRequired String?             @db.Text
  status           ReadinessGateStatus @default(NOT_STARTED)
  ownerText        String?
  confidence       Confidence          @default(INFERRED)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([readinessGateId])
  @@index([status])
}

model GovernanceMeeting {
  id               String                @id @default(cuid())
  externalId       String                @unique
  programmeId      String?
  programme        Programme?            @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  workstreamId     String?
  workstream       Workstream?           @relation(fields: [workstreamId], references: [id], onDelete: SetNull)
  type             GovernanceMeetingType
  name             String
  purpose          String?               @db.Text
  cadence          String?
  scheduledDate    String?
  ownerPersonId    String?
  ownerPerson      Person?               @relation("GovernanceMeetingOwner", fields: [ownerPersonId], references: [id], onDelete: SetNull)
  ownerText        String?
  requiredInputs   String?               @db.Text
  expectedOutputs  String?               @db.Text
  escalationPath   String?               @db.Text
  decisionRefs     String?
  sourceDocumentId String?
  sourceDocument   SourceDocument?       @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  traceRef         String?
  confidence       Confidence            @default(INFERRED)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  statusUpdates    StatusUpdate[]
  evidenceLinks    EvidenceLink[]

  @@index([programmeId])
  @@index([workstreamId])
  @@index([type])
  @@index([scheduledDate])
}

model StatusUpdate {
  id                  String             @id @default(cuid())
  programmeId         String?
  programme           Programme?         @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  phaseId             String?
  phase               Phase?             @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  workstreamId        String?
  workstream          Workstream?        @relation(fields: [workstreamId], references: [id], onDelete: SetNull)
  projectId           String?
  project             Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  taskId              String?
  task                Task?              @relation(fields: [taskId], references: [id], onDelete: SetNull)
  readinessGateId     String?
  readinessGate       ReadinessGate?     @relation(fields: [readinessGateId], references: [id], onDelete: SetNull)
  governanceMeetingId String?
  governanceMeeting   GovernanceMeeting? @relation(fields: [governanceMeetingId], references: [id], onDelete: SetNull)
  title               String
  body                String             @db.Text
  rag                 Rag?
  status              String?
  reportedBy          String?
  reportedAt          DateTime           @default(now())
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([programmeId])
  @@index([phaseId])
  @@index([workstreamId])
  @@index([projectId])
  @@index([taskId])
  @@index([readinessGateId])
}

model Comment {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  authorText String?
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityType, entityId])
}

model Attachment {
  id               String          @id @default(cuid())
  entityType       String
  entityId         String
  name             String
  description      String?         @db.Text
  mimeType         String?
  storageRef       String?
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([entityType, entityId])
  @@index([sourceDocumentId])
}

model EvidenceLink {
  id                  String             @id @default(cuid())
  kind                EvidenceLinkKind   @default(SUPPORTS)
  entityType          String
  entityId            String
  sourceDocumentId    String?
  sourceDocument      SourceDocument?    @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  workstreamId        String?
  workstream          Workstream?        @relation(fields: [workstreamId], references: [id], onDelete: SetNull)
  deliverableId       String?
  deliverable         Deliverable?       @relation(fields: [deliverableId], references: [id], onDelete: SetNull)
  taskId              String?
  task                Task?              @relation(fields: [taskId], references: [id], onDelete: SetNull)
  actionId            String?
  action              Action?            @relation(fields: [actionId], references: [id], onDelete: SetNull)
  riskId              String?
  risk                Risk?              @relation(fields: [riskId], references: [id], onDelete: SetNull)
  issueId             String?
  issue               Issue?             @relation(fields: [issueId], references: [id], onDelete: SetNull)
  decisionId          String?
  decision            Decision?          @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  dependencyId        String?
  dependency          Dependency?        @relation(fields: [dependencyId], references: [id], onDelete: SetNull)
  milestoneId         String?
  milestone           Milestone?         @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  readinessGateId     String?
  readinessGate       ReadinessGate?     @relation(fields: [readinessGateId], references: [id], onDelete: SetNull)
  governanceMeetingId String?
  governanceMeeting   GovernanceMeeting? @relation(fields: [governanceMeetingId], references: [id], onDelete: SetNull)
  extractedText       String?            @db.Text
  notes               String?            @db.Text
  followUpRequired    Boolean            @default(false)
  confidence          Confidence         @default(INFERRED)
  traceRef            String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([entityType, entityId])
  @@index([sourceDocumentId])
  @@index([workstreamId])
  @@index([deliverableId])
  @@index([taskId])
  @@index([readinessGateId])
  @@index([kind])
}

model Project {
  id             String          @id @default(cuid())
  programmeId    String?
  programme      Programme?      @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  workstreamId   String?
  workstream     Workstream?     @relation(fields: [workstreamId], references: [id], onDelete: SetNull)
  code           String?         @unique
  name           String
  description    String?         @db.Text
  status         ProjectStatus   @default(ACTIVE)
  priority       Priority        @default(MEDIUM)
  rag            Rag?
  ownerPersonId  String?
  ownerPerson    Person?         @relation("ProjectOwner", fields: [ownerPersonId], references: [id], onDelete: SetNull)
  ownerText      String?
  sponsor        String?
  startDate      String?
  endDate        String?
  budgetNote     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  milestones     Milestone[]
  deliverables   Deliverable[]
  tasks          Task[]
  actions        Action[]
  risks          Risk[]
  issues         Issue[]
  dependencies   Dependency[]
  documents      Document[]
  changeRequests ChangeRequest[]
  readinessGates ReadinessGate[]
  statusUpdates  StatusUpdate[]

  @@index([programmeId])
  @@index([workstreamId])
  @@index([status])
}

model Deliverable {
  id                  String            @id @default(cuid())
  externalId          String?           @unique
  programmeId         String?
  programme           Programme?        @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  phaseId             String?
  phase               Phase?            @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  workstreamId        String?
  workstream          Workstream?       @relation(fields: [workstreamId], references: [id], onDelete: SetNull)
  projectId           String?
  project             Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  name                String
  description         String?           @db.Text
  status              DeliverableStatus @default(NOT_STARTED)
  rag                 Rag?
  startDate           String?
  dueDate             String?
  ownerPersonId       String?
  ownerPerson         Person?           @relation("DeliverableOwner", fields: [ownerPersonId], references: [id], onDelete: SetNull)
  ownerText           String?
  acceptanceCriteria  String?           @db.Text
  approvalRequirement String?           @db.Text
  evidenceRequired    String?           @db.Text
  completionEvidence  String?           @db.Text
  confidence          Confidence        @default(INFERRED)
  sourceDocumentId    String?
  sourceDocument      SourceDocument?   @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  traceRef            String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  milestones          Milestone[]
  tasks               Task[]
  actions             Action[]
  risks               Risk[]
  decisions           Decision[]
  dependencies        Dependency[]
  readinessGates      ReadinessGate[]
  evidenceLinks       EvidenceLink[]

  @@index([programmeId])
  @@index([phaseId])
  @@index([workstreamId])
  @@index([projectId])
  @@index([status])
  @@index([rag])
}

model ChangeRequest {
  id                   String              @id @default(cuid())
  externalId           String              @unique
  title                String
  description          String              @db.Text
  projectId            String?
  project              Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  impactAssessment     String?             @db.Text
  priority             Priority            @default(MEDIUM)
  status               ChangeRequestStatus @default(SUBMITTED)
  requestedBy          String?
  approverPersonId     String?
  approverPerson       Person?             @relation("ChangeApprover", fields: [approverPersonId], references: [id], onDelete: SetNull)
  outcome              String?             @db.Text
  implementationStatus String?
  decidedAt            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([status])
  @@index([projectId])
}

model Approval {
  id               String         @id @default(cuid())
  externalId       String         @unique
  title            String
  entityType       String
  entityId         String?
  summary          String?        @db.Text
  status           ApprovalStatus @default(PENDING)
  priority         Priority       @default(MEDIUM)
  requestedBy      String?
  approverPersonId String?
  approverPerson   Person?        @relation("ApprovalApprover", fields: [approverPersonId], references: [id], onDelete: SetNull)
  approverText     String?
  decisionReason   String?        @db.Text
  decidedAt        DateTime?
  dueDate          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([status])
  @@index([entityType, entityId])
}

model Resource {
  id            String               @id @default(cuid())
  personId      String?              @unique
  person        Person?              @relation(fields: [personId], references: [id], onDelete: SetNull)
  displayName   String
  role          String?
  team          String?
  capacityHours Int?
  notes         String?              @db.Text
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  allocations   ResourceAllocation[]

  @@index([team])
}

model ResourceAllocation {
  id             String   @id @default(cuid())
  resourceId     String
  resource       Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  personId       String?
  person         Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  projectId      String?
  workstreamCode String?
  roleOnWork     String?
  allocationPct  Int      @default(0)
  startDate      String?
  endDate        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([resourceId])
  @@index([projectId])
}

model Document {
  id            String         @id @default(cuid())
  name          String
  description   String?        @db.Text
  projectId     String?
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  relatedType   String?
  relatedId     String?
  mimeType      String?
  version       String?
  status        DocumentStatus @default(DRAFT)
  storageRef    String?
  ownerPersonId String?
  ownerPerson   Person?        @relation("DocumentOwner", fields: [ownerPersonId], references: [id], onDelete: SetNull)
  ownerText     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([relatedType, relatedId])
}

model Notification {
  id                String           @id @default(cuid())
  recipientPersonId String?
  recipientPerson   Person?          @relation("NotificationRecipient", fields: [recipientPersonId], references: [id], onDelete: SetNull)
  type              NotificationType @default(INFO)
  priority          Priority         @default(MEDIUM)
  title             String
  body              String?          @db.Text
  relatedType       String?
  relatedId         String?
  actionUrl         String?
  read              Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([recipientPersonId])
  @@index([read])
}

// ─── Access control (governance UI; not yet enforced as auth) ────────────────

model User {
  id          String     @id @default(cuid())
  email       String     @unique
  displayName String
  personId    String?    @unique
  person      Person?    @relation(fields: [personId], references: [id], onDelete: SetNull)
  active      Boolean    @default(true)
  externalRef String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  roles       UserRole[]

  @@index([active])
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?          @db.Text
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  entity      String
  action      String
  description String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@index([entity])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
}
