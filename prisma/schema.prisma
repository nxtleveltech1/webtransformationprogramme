// ─── Cross-cutting ───────────────────────────────────────────────────────────

model RegisterLink {
  id             String       @id @default(cuid())
  fromType       RegisterType
  fromExternalId String
  toType         RegisterType
  toExternalId   String
  linkKind       LinkKind     @default(RELATED)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([fromType, fromExternalId, toType, toExternalId, linkKind])
  @@index([fromExternalId])
  @@index([toExternalId])
}

model TraceReference {
