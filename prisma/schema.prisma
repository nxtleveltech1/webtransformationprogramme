// Web Transformation Workshop Programme — Neon PostgreSQL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ProgrammeStatus {
  ACTIVE
  COMPLETE
  ARCHIVED
}

enum WorkshopStatus {
  PLANNED
  IN_PROGRESS
  COMPLETE
}

enum Confidence {
  CONFIRMED
  INFERRED
  UNCONFIRMED
  REQUIRES_VALIDATION
}

enum DecisionStatus {
  CONFIRMED
  PROPOSED
  DEFERRED
  REJECTED
  UNCLEAR
}

enum ActionStatus {
  NEW
  IN_PROGRESS
  BLOCKED
  DONE
  UNCONFIRMED
  SUGGESTED
  OPEN
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum RiskCategory {
  BUSINESS
  TECHNICAL
  PROCESS
  PEOPLE
  RESOURCE
  GOVERNANCE
  DATA
  SECURITY
  TIMELINE
  FINANCIAL
  VENDOR
  CHANGE
  DELIVERY
}

enum Probability {
  HIGH
  MEDIUM
  LOW
  UNKNOWN
}

enum Impact {
  HIGH
  MEDIUM
  LOW
  UNKNOWN
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum DependencyStatus {
  OPEN
  IN_PROGRESS
  MET
  BLOCKED
  AT_RISK
}

enum QuestionStatus {
  OPEN
  ANSWERED
  DEFERRED
}

enum IngestStatus {
  INGESTED
  PARTIAL
  RECONCILED
  EXCLUDED
  PENDING
}

enum AnalysisLens {
  A_PROCESS
  B_RACI
  C_RESOURCING
  D_TECHNICAL
  E_DELIVERY
  F_STAKEHOLDER
  G_CHANGE
}

enum AnalysisCompleteness {
  COMPLETE
  INCOMPLETE
}

enum RegisterType {
  DECISION
  ACTION
  RISK
  ISSUE
  ASSUMPTION
  DEPENDENCY
  OPEN_QUESTION
  PARKING_LOT
  TRADEOFF
}

enum LinkKind {
  RELATED
  BLOCKS
  MITIGATES
  ANSWERS
  IMPLEMENTS
  TRACES
  ESCALATES
}

enum SessionOutputType {
  SUMMARY
  KEY_POINTS
  DECISIONS
  ACTIONS
  RISKS
  ISSUES
  DEPENDENCIES
  OPEN_QUESTIONS
  PARKING_LOT
  CLARIFICATIONS
}

enum ExecutiveSummaryDay {
  DAY1
  DAY2
  FINAL
}

enum ExportArtifactType {
  XLSX
  HTML
}

enum ExportVariant {
  CANONICAL
  CURSOR
  GPT
}

enum MetricCategory {
  PLATFORM
  CUSTOMER
}

enum GlossaryCategory {
  ACRONYM
  SYSTEM
  TERM
  PROCESS
  GEOGRAPHY
}

enum ContactVisibility {
  PUBLIC_INTERNAL
  RESTRICTED
  NAME_ONLY
}

enum PersonKind {
  PERSON
  GROUP
}

enum ProgrammeRoleType {
  STREAM_LEAD
  PRODUCT_OWNER
  SME
  GATEKEEPER
  FACILITATOR
  TECHNICAL_ARCHITECT
  BUSINESS_STAKEHOLDER
  SPONSOR
  CONTRIBUTOR
  PROGRAMME_DIRECTOR
  SCRIBE
  EXECUTIVE_SPONSOR
}

enum GovernanceDocType {
  TERMS_OF_REFERENCE
  POLICY
  STANDARD
  DEFINITION_SET
}

enum GovernanceDocStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DsZone {
  RED
  GREEN
  MIXED
}

enum PageTreatment {
  AS_IS
  NEW_TEMPLATE
  RESTYLE
  CONSOLIDATE
  RETIRE
}

enum ParticipantStatus {
  CONFIRMED
  PENDING
  TO_BE_CONFIRMED
  INACTIVE
}

enum StakeholderRoleType {
  SPONSOR
  APPROVER
  SME
  DECISION_MAKER
  INFORMED
  STEERCING_MEMBER
  CONSULTATION
  COMMUNICATION
  WORKING_TEAM
}

// ─── Programme & workshop ────────────────────────────────────────────────────

model Programme {
  id                 String              @id @default(cuid())
  name               String
  purpose            String?             @db.Text
  scopeTension       String?             @db.Text
  hardDeadline       String?
  pageBaseline       Int?
  mvpSummary         String?             @db.Text
  rag                Rag?
  status             ProgrammeStatus     @default(ACTIVE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  workshops          WorkshopEvent[]
  workstreams        Workstream[]
  sites              Site[]
  metrics            SuccessMetric[]
  scopeOptions       ScopeOption[]
  projects           Project[]
  phases             Phase[]
  tasks              Task[]
  deliverables       Deliverable[]
  readinessGates     ReadinessGate[]
  governanceMeetings    GovernanceMeeting[]
  statusUpdates         StatusUpdate[]
  governanceReferenceDocs GovernanceReferenceDoc[]
  scenarios             Scenario[]
}

model WorkshopEvent {
  id          String             @id @default(cuid())
  programmeId String
  programme   Programme          @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  title       String
  location    String?
  startDate   DateTime?
  endDate     DateTime?
  status      WorkshopStatus     @default(IN_PROGRESS)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  days        WorkshopDay[]
  sources     SourceDocument[]
  sessions    WorkshopSession[]
  summaries   ExecutiveSummary[]
}

model WorkshopDay {
  id         String            @id @default(cuid())
  workshopId String
  workshop   WorkshopEvent     @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  dayNumber  Int
  date       DateTime?
  theme      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  sessions   WorkshopSession[]

  @@unique([workshopId, dayNumber])
}

model WorkshopSession {
  id                 String              @id @default(cuid())
  workshopId         String
  workshop           WorkshopEvent       @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  dayId              String?
  day                WorkshopDay?        @relation(fields: [dayId], references: [id], onDelete: SetNull)
  sessionNumber      Int
  name               String
  startTime          String?
  endTime            String?
  facilitator        String?
  scribe             String?
  purpose            String?             @db.Text
  location           String?
  bodyMarkdown       String?             @db.Text
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  agendaItems        SessionAgendaItem[]
  topics             SessionTopic[]
  outputs            SessionOutput[]
  transcriptExcerpts TranscriptExcerpt[]

  @@unique([workshopId, dayId, sessionNumber])
  @@index([dayId])
}

model SessionAgendaItem {
  id        String          @id @default(cuid())
  sessionId String
  session   WorkshopSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title     String
  covered   Boolean         @default(true)
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([sessionId])
}

model SessionTopic {
  id                   String          @id @default(cuid())
  sessionId            String
  session              WorkshopSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title                String
  summary              String?         @db.Text
  businessImplication  String?         @db.Text
  technicalImplication String?         @db.Text
  sortOrder            Int             @default(0)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([sessionId])
}

model SessionOutput {
  id           String            @id @default(cuid())
  sessionId    String
  session      WorkshopSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  outputType   SessionOutputType
  bodyMarkdown String?           @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([sessionId])
}

// ─── Sources & ingestion ─────────────────────────────────────────────────────

model SourceDocument {
  id                 String                 @id @default(cuid())
  workshopId         String?
  workshop           WorkshopEvent?         @relation(fields: [workshopId], references: [id], onDelete: SetNull)
  externalId         String                 @unique
  filePath           String
  mimeType           String?
  workshopDay        Int?
  authoritativeFor   String?                @db.Text
  ingestStatus       IngestStatus           @default(INGESTED)
  excludedReason     String?                @db.Text
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  reconciliations    ReconciliationRecord[]
  transcriptExcerpts TranscriptExcerpt[]
  decisions          Decision[]
  actions            Action[]
  risks              Risk[]
  issues             Issue[]
  assumptions        Assumption[]
  dependencies       Dependency[]
  openQuestions      OpenQuestion[]
  parkingLotItems    ParkingLotItem[]
  deliverables       Deliverable[]
  tasks              Task[]
  readinessGates     ReadinessGate[]
  governanceMeetings GovernanceMeeting[]
  evidenceLinks      EvidenceLink[]
  attachments        Attachment[]

  @@index([workshopDay])
  @@index([ingestStatus])
}

model IngestionLogEntry {
  id         String   @id @default(cuid())
  occurredAt DateTime @default(now())
  action     String
  sourceIds  String[]
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ReconciliationRecord {
  id                      String          @id @default(cuid())
  sourceDocumentId        String?
  sourceDocument          SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  sourceExternalId        String?
  conflict                String?         @db.Text
  disposition             String?         @db.Text
  humanValidationRequired Boolean         @default(false)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([sourceExternalId])
}

model TranscriptExcerpt {
  id               String           @id @default(cuid())
  sourceDocumentId String?
  sourceDocument   SourceDocument?  @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  sessionId        String?
  session          WorkshopSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  speakerName      String?
  text             String           @db.Text
  approximateTime  String?
  confidence       Confidence       @default(UNCONFIRMED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

// ─── Organisation ────────────────────────────────────────────────────────────

model DirectoryArea {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  people    Person[] @relation("PersonArea")
}

model DirectoryBusiness {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  people    Person[] @relation("PersonBusiness")
}

model DirectoryCluster {
  id            String   @id @default(cuid())
  key           String   @unique
  name          String
  audienceLabel String?
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  people        Person[] @relation("PersonCluster")
}

model Person {
  id                      String                    @id @default(cuid())
  displayName             String
  surname                 String?
  nickname                String?
  email                   String?
  phone                   String?
  mobile                  String?
  primaryContact          String?
  roleDescription         String?                   @db.Text
  department              String?
  location                String?
  participantStatus       ParticipantStatus         @default(CONFIRMED)
  kind                    PersonKind                @default(PERSON)
  confidence              Confidence                @default(INFERRED)
  active                  Boolean                   @default(true)
  contactVisibility       ContactVisibility         @default(PUBLIC_INTERNAL)
  areaId                  String?
  area                    DirectoryArea?            @relation("PersonArea", fields: [areaId], references: [id], onDelete: SetNull)
  businessId              String?
  business                DirectoryBusiness?        @relation("PersonBusiness", fields: [businessId], references: [id], onDelete: SetNull)
  clusterId               String?
  cluster                 DirectoryCluster?         @relation("PersonCluster", fields: [clusterId], references: [id], onDelete: SetNull)
  primaryWorkstreamId     String?
  primaryWorkstream       Workstream?               @relation("PersonPrimaryWorkstream", fields: [primaryWorkstreamId], references: [id], onDelete: SetNull)
  dataOwnerPersonId       String?
  dataOwner               Person?                   @relation("PersonDataOwner", fields: [dataOwnerPersonId], references: [id], onDelete: SetNull)
  dataStewards            Person[]                  @relation("PersonDataOwner")
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  teamAssignments         PersonTeam[]
  stakeholderRoles        StakeholderRole[]
  programmeRoles          ProgrammeRoleAssignment[]
  ledWorkstreams          Workstream[]              @relation("WorkstreamLead")
  ownedDecisions          Decision[]                @relation("DecisionOwner")
  ownedActions            Action[]                  @relation("ActionOwner")
  ownedRisks              Risk[]                    @relation("RiskOwner")
  ownedIssues             Issue[]                   @relation("IssueOwner")
  validatedAssumptions    Assumption[]              @relation("AssumptionValidator")
  ownedProjects           Project[]                 @relation("ProjectOwner")
  ownedDeliverables       Deliverable[]             @relation("DeliverableOwner")
  ownedTasks              Task[]                    @relation("TaskOwner")
  ownedReadinessGates     ReadinessGate[]           @relation("ReadinessGateOwner")
  ownedGovernanceMeetings GovernanceMeeting[]       @relation("GovernanceMeetingOwner")
  approvals               Approval[]                @relation("ApprovalApprover")
  changeApprovals         ChangeRequest[]           @relation("ChangeApprover")
  allocations             ResourceAllocation[]
  notifications           Notification[]            @relation("NotificationRecipient")
  ownedDocuments          Document[]                @relation("DocumentOwner")
  ownedGovernanceDocs     GovernanceReferenceDoc[]  @relation("GovernanceDocOwner")
  userAccount             User?
  resource                Resource?

  @@unique([displayName, surname])
  @@index([displayName])
  @@index([kind])
  @@index([areaId])
  @@index([businessId])
  @@index([clusterId])
  @@index([active])
  @@index([primaryWorkstreamId])
}

model ProgrammeRoleAssignment {
  id           String            @id @default(cuid())
  personId     String
  person       Person            @relation(fields: [personId], references: [id], onDelete: Cascade)
  roleType     ProgrammeRoleType
  scope        String?           @db.Text
  isPrimary    Boolean           @default(false)
  workstreamId String?
  workstream   Workstream?       @relation("ProgrammeRoleWorkstream", fields: [workstreamId], references: [id], onDelete: SetNull)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([personId, roleType, scope])
  @@index([personId])
  @@index([roleType])
}

model Team {
  id                  String       @id @default(cuid())
  name                String       @unique
  functionDescription String?      @db.Text
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  members             PersonTeam[]
}

model PersonTeam {
  id        String   @id @default(cuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([personId, teamId])
}

model Workstream {
  id                 String              @id @default(cuid())
  programmeId        String?
  programme          Programme?          @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  code               String              @unique
  name               String
  leadPersonId       String?
  leadPerson         Person?             @relation("WorkstreamLead", fields: [leadPersonId], references: [id], onDelete: SetNull)
  leadText           String?
  oneLineStatus      String?             @db.Text
  rag                Rag?
  sortOrder          Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  decisions          Decision[]
  actions            Action[]
  risks              Risk[]
  dependencies       Dependency[]
  projects           Project[]
  milestones         Milestone[]
  tasks              Task[]
  deliverables       Deliverable[]
  readinessGates     ReadinessGate[]
  governanceMeetings GovernanceMeeting[]
  statusUpdates      StatusUpdate[]
  evidenceLinks      EvidenceLink[]
  primaryForPeople   Person[]                @relation("PersonPrimaryWorkstream")
  programmeRoles     ProgrammeRoleAssignment[] @relation("ProgrammeRoleWorkstream")

  @@index([programmeId])
}

model StakeholderRole {
  id        String              @id @default(cuid())
  personId  String
  person    Person              @relation(fields: [personId], references: [id], onDelete: Cascade)
  roleType  StakeholderRoleType
  roleLabel String?             @db.Text
  scope     String?             @db.Text
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([personId])
}

// ─── Domain catalogue ────────────────────────────────────────────────────────

model Site {
  id               String              @id @default(cuid())
  programmeId      String?
  programme        Programme?          @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  name             String
  brand            String?
  country          String?
  tenantNotes      String?             @db.Text
  validationStatus Confidence          @default(UNCONFIRMED)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  pageItems        PageMigrationItem[]

  @@index([programmeId])
}

model CustomerJourney {
  id           String   @id @default(cuid())
  name         String
  businessArea String?
  cluster      String?
  notes        String?  @db.Text
  traceRef     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GlossaryTerm {
  id         String           @id @default(cuid())
  term       String
  meaning    String           @db.Text
  category   GlossaryCategory @default(TERM)
  confidence Confidence       @default(INFERRED)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  mappings   ReferenceMapping[]

  @@unique([term])
}

model GovernanceReferenceDoc {
  id            String                      @id @default(cuid())
  type          GovernanceDocType           @default(TERMS_OF_REFERENCE)
  title         String
  slug          String                      @unique
  version       String                      @default("1.0")
  status        GovernanceDocStatus         @default(DRAFT)
  summary       String?                     @db.Text
  programmeId   String?
  programme     Programme?                  @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  ownerPersonId String?
  ownerPerson   Person?                     @relation("GovernanceDocOwner", fields: [ownerPersonId], references: [id], onDelete: SetNull)
  publishedAt   DateTime?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  sections      GovernanceReferenceSection[]

  @@index([type])
  @@index([status])
}

model GovernanceReferenceSection {
  id               String                      @id @default(cuid())
  docId            String
  doc              GovernanceReferenceDoc      @relation(fields: [docId], references: [id], onDelete: Cascade)
  heading          String
  body             String                      @db.Text
  sortOrder        Int                         @default(0)
  parentSectionId  String?
  parentSection    GovernanceReferenceSection? @relation("SectionHierarchy", fields: [parentSectionId], references: [id], onDelete: SetNull)
  childSections    GovernanceReferenceSection[] @relation("SectionHierarchy")
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  referenceMaps    ReferenceMapping[]

  @@index([docId])
  @@index([parentSectionId])
}

model ReferenceMapping {
  id                  String                      @id @default(cuid())
  conceptKey          String
  label               String
  description         String                      @db.Text
  glossaryTermId      String?
  glossaryTerm        GlossaryTerm?               @relation(fields: [glossaryTermId], references: [id], onDelete: SetNull)
  entityType          String?
  fieldPath           String?
  processName         String?
  relatedDocSectionId String?
  relatedDocSection   GovernanceReferenceSection? @relation(fields: [relatedDocSectionId], references: [id], onDelete: SetNull)
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  @@index([conceptKey])
  @@index([glossaryTermId])
}

model SystemPlatform {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String?
  ownerTeam String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Milestone {
  id            String         @id @default(cuid())
  title         String
  targetDate    String?
  piGate        String?
  phaseId       String?
  phase         Phase?         @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  workstreamId  String?
  workstream    Workstream?    @relation(fields: [workstreamId], references: [id], onDelete: SetNull)
  projectId     String?
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  deliverableId String?
  deliverable   Deliverable?   @relation(fields: [deliverableId], references: [id], onDelete: SetNull)
  status        String?
  varianceDays  Int?
  notes         String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tasks         Task[]
  evidenceLinks EvidenceLink[]

  @@index([phaseId])
  @@index([workstreamId])
  @@index([projectId])
  @@index([deliverableId])
}

model SuccessMetric {
  id          String         @id @default(cuid())
  programmeId String?
  programme   Programme?     @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  name        String
  category    MetricCategory
  confirmed   Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([programmeId])
}

model ScopeOption {
  id          String     @id @default(cuid())
  programmeId String?
  programme   Programme? @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  name        String
  description String?    @db.Text
  appetite    String?
  status      String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

/// Saved what-if schedule scenario. Models date shifts against the live
/// baseline so leadership can compare the impact on the programme end date and
/// critical path without mutating real task/milestone data.
model Scenario {
  id          String           @id @default(cuid())
  name        String
  description String?          @db.Text
  status      ScenarioStatus   @default(DRAFT)
  programmeId String?
  programme   Programme?       @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  changes     ScenarioChange[]

  @@index([programmeId])
  @@index([status])
}

/// A single what-if adjustment within a scenario: shift a task or milestone by
/// a number of days relative to its current schedule.
model ScenarioChange {
  id          String             @id @default(cuid())
  scenarioId  String
  scenario    Scenario           @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  targetType  ScenarioTargetType
  targetId    String
  targetLabel String?
  deltaDays   Int                @default(0)
  note        String?            @db.Text
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([scenarioId])
  @@index([targetType, targetId])
}

enum ScenarioStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ScenarioTargetType {
  TASK
  MILESTONE
}

model PageMigrationItem {
  id             String         @id @default(cuid())
  siteId         String?
  site           Site?          @relation(fields: [siteId], references: [id], onDelete: SetNull)
  url            String?
  treatment      PageTreatment?
  effortEstimate String?
  ownerName      String?
  status         String?
  notes          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ComponentTemplate {
  id                 String   @id @default(cuid())
  name               String
  dsZone             DsZone?
  contentstackMapped Boolean?
  status             String?
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Registers ───────────────────────────────────────────────────────────────

model Decision {
  id                String          @id @default(cuid())
  externalId        String          @unique
  category          String?
  title             String?
  description       String          @db.Text
  status            DecisionStatus  @default(PROPOSED)
  ownerPersonId     String?
  ownerPerson       Person?         @relation("DecisionOwner", fields: [ownerPersonId], references: [id], onDelete: SetNull)
  ownerText         String?
  approver          String?
  requiredDecision  String?
  dueDate           String?
  rationale         String?         @db.Text
  optionsConsidered String?         @db.Text
  tradeoffs         String?         @db.Text
  followUp          String?         @db.Text
  workshopDay       Int?
  sessionRef        String?
  traceRef          String?
  workstreamId      String?
  workstream        Workstream?     @relation(fields: [workstreamId], references: [id], onDelete: SetNull)
  sourceDocumentId  String?
  sourceDocument    SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  taskId            String?
  task              Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  deliverableId     String?
